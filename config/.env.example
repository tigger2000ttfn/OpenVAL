# ============================================================
# OpenVAL Environment Configuration Template
# Copy to /opt/openval/.env and set chmod 600
# NEVER commit this file to version control
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=OpenVAL
APP_VERSION=1.0.0
APP_ENV=production
# Options: production | staging | development
DEBUG=false
SITE_URL=https://openval.yoursite.com
# Comma-separated if multiple (e.g., openval.yoursite.com,openval-internal.yoursite.com)
ALLOWED_HOSTS=openval.yoursite.com

# ── Edition and License ──────────────────────────────────────
# Leave blank for Community Edition
# Set to your Enterprise license key for EE features
LICENSE_KEY=

# ── Security (GENERATE UNIQUE VALUES - never use these defaults) ──
# python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_GENERATE_64_CHAR_RANDOM_HEX

# python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_BASE64

JWT_ALGORITHM=HS256

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://openval_app:CHANGE_DB_PASSWORD@localhost/openval
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_REDIS_PASSWORD@localhost:6379/0
CELERY_BROKER_URL=redis://:CHANGE_REDIS_PASSWORD@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_REDIS_PASSWORD@localhost:6379/2

# ── Email / SMTP ──────────────────────────────────────────────
SMTP_HOST=mail.yoursite.com
SMTP_PORT=587
SMTP_USER=openval@yoursite.com
SMTP_PASSWORD=CHANGE_SMTP_PASSWORD
SMTP_FROM_ADDRESS=openval@yoursite.com
SMTP_FROM_NAME=OpenVAL
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ── File Storage ──────────────────────────────────────────────
MEDIA_ROOT=/opt/openval/media
# Max single file upload size in megabytes
MAX_UPLOAD_SIZE_MB=50
# Comma-separated list of allowed extensions
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,png,jpg,jpeg,gif,webp,txt,csv,zip,xml,json

# ── Session and Authentication ────────────────────────────────
# JWT access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7
# Session idle timeout in minutes (0 = no idle timeout)
SESSION_IDLE_TIMEOUT_MINUTES=30
# Absolute session timeout in hours (0 = no absolute timeout)
SESSION_ABSOLUTE_TIMEOUT_HOURS=8
# Maximum concurrent sessions per user (0 = unlimited)
MAX_CONCURRENT_SESSIONS=3

# ── Password Policy ───────────────────────────────────────────
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
# Number of previous passwords that cannot be reused
PASSWORD_HISTORY_COUNT=12
# Days before password must be changed (0 = never)
PASSWORD_EXPIRY_DAYS=0

# ── Account Security ──────────────────────────────────────────
# Failed login attempts before account lockout
LOGIN_MAX_ATTEMPTS=5
# Lockout duration in minutes
LOGIN_LOCKOUT_MINUTES=15
# Require MFA for all users (true/false)
MFA_REQUIRED_FOR_ALL=false
# Require MFA for electronic signature actions
MFA_REQUIRED_FOR_SIGNATURES=true

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=/opt/openval/logs/openval.log
# Log format: json (structured) or text
LOG_FORMAT=json
# Request correlation ID header name
CORRELATION_ID_HEADER=X-Request-ID

# ── Community Edition Limits ──────────────────────────────────
# These are enforced for CE. EE overrides with license.
CE_MAX_USERS=50
CE_MAX_SITES=1

# ── Optional: LDAP / Active Directory ────────────────────────
# Leave blank to disable LDAP
LDAP_SERVER_URL=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_FILTER=(&(objectClass=person)(sAMAccountName={username}))
LDAP_USERNAME_ATTRIBUTE=sAMAccountName
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_FULL_NAME_ATTRIBUTE=displayName
# Sync interval in minutes (0 = manual only)
LDAP_SYNC_INTERVAL_MINUTES=60

# ── Optional: SSO (Enterprise Edition only) ──────────────────
# SAML or OIDC. Leave blank to disable.
SSO_PROVIDER_TYPE=
# For SAML: metadata URL
SSO_SAML_METADATA_URL=
# For OIDC: discovery URL
SSO_OIDC_DISCOVERY_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# ── Optional: Virus Scanning ──────────────────────────────────
# Leave blank to disable (not recommended for production)
CLAMAV_HOST=
CLAMAV_PORT=3310

# ── Optional: S3-compatible Storage (future) ─────────────────
# Leave blank to use local filesystem (default)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=

# ── Celery Task Settings ──────────────────────────────────────
# Number of Celery worker processes
CELERY_CONCURRENCY=4
# Maximum tasks per worker before restart (memory leak prevention)
CELERY_MAX_TASKS_PER_CHILD=1000

# ── Scheduled Task Times (24h format, server local time) ──────
# Nightly audit chain integrity verification
AUDIT_CHAIN_CHECK_TIME=02:00
# Daily overdue item alerts
OVERDUE_ALERTS_TIME=08:00
# Daily periodic review reminders
REVIEW_REMINDERS_TIME=07:00
# Nightly session cleanup
SESSION_CLEANUP_TIME=01:00

# ── Performance ───────────────────────────────────────────────
# Number of Gunicorn worker processes
# Recommended: (2 * CPU_CORES) + 1
GUNICORN_WORKERS=4
# Maximum requests per worker before restart
GUNICORN_MAX_REQUESTS=1000
# Request timeout in seconds
GUNICORN_TIMEOUT=120
